# ── Email (Resend) — see SETUP.md ────────────────────────────────────────────
# API key from https://resend.com/api-keys
RESEND_API_KEY=
# Where booking requests arrive (default: jessicabertoncello@gmail.com)
BOOKING_TO=jessicabertoncello@gmail.com
# Sender. Without a verified domain use the Resend sandbox sender:
BOOKING_FROM=Predator Fishing Italy <onboarding@resend.dev>

# ── Google Calendar (availability + auto-block) — see SETUP.md ───────────────
# Service account email, e.g. booking@my-project.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_EMAIL=
# The service account's private key (keep the \n escapes, wrap in quotes)
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# The calendar to read/write. Roberto's Gmail address, or a dedicated
# calendar's ID from Google Calendar settings.
GOOGLE_CALENDAR_ID=
